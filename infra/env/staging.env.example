BACKEND_IMAGE=ghcr.io/example/movy-backend:staging-replace-me
FRONTEND_IMAGE=ghcr.io/example/movy-frontend:staging-replace-me
NODE_ENV=production
BACKEND_PORT=3333
JWT_SECRET=replace-with-staging-secret
MOVY_DATA_MODE=prisma
DATABASE_URL=postgresql://movy:replace-me@postgres:5432/movy_staging
REDIS_URL=redis://redis:6379
CORS_ALLOWED_ORIGINS=https://staging.movy.local
LOG_LEVEL=info
TRUST_PROXY=true
RATE_LIMIT_MAX=120
RATE_LIMIT_WINDOW_MS=60000
HELMET_ENABLED=true
EXPO_PUBLIC_API_URL=https://api.staging.movy.local
MOVY_DEMO_ADMIN_EMAIL=admin-staging@movy.local
MOVY_DEMO_ADMIN_PASSWORD=replace-me
MOVY_ALLOW_DASHBOARD_FALLBACK=false
MOVY_DEMO_PASSENGER_EMAIL=ana-staging@movy.local
MOVY_DEMO_PASSENGER_PASSWORD=replace-me
MOVY_DEMO_DRIVER_EMAIL=carlos-staging@movy.local
MOVY_DEMO_DRIVER_PASSWORD=replace-me
STAGING_POSTGRES_DB=movy_staging
STAGING_POSTGRES_USER=movy
STAGING_POSTGRES_PASSWORD=replace-me
STAGING_PUBLIC_API_URL=https://api.staging.movy.local
STAGING_PUBLIC_WS_URL=https://api.staging.movy.local
