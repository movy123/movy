BACKEND_PORT=3333
JWT_SECRET=movy-local-secret
# Use `memory` for zero-dependency local dev or `prisma` after `npm run prisma:bootstrap:local`
MOVY_DATA_MODE=memory
DATABASE_URL=postgresql://movy:movy@localhost:5432/movy
REDIS_URL=redis://localhost:6379
CORS_ALLOWED_ORIGINS=http://localhost:3000
LOG_LEVEL=debug
TRUST_PROXY=false
RATE_LIMIT_MAX=120
RATE_LIMIT_WINDOW_MS=60000
HELMET_ENABLED=true
NEXT_PUBLIC_API_URL=http://localhost:3333
NEXT_PUBLIC_WS_URL=http://localhost:3333
EXPO_PUBLIC_API_URL=http://localhost:3333
MOVY_DEMO_ADMIN_EMAIL=admin@movy.local
MOVY_DEMO_ADMIN_PASSWORD=admin123
MOVY_DEMO_ADMIN_MFA_ENABLED=true
MOVY_ALLOW_DASHBOARD_FALLBACK=true
MOVY_DEMO_PASSENGER_EMAIL=ana@movy.local
MOVY_DEMO_PASSENGER_PASSWORD=123456
MOVY_DEMO_DRIVER_EMAIL=carlos@movy.local
MOVY_DEMO_DRIVER_PASSWORD=123456
MOVY_FRONTEND_STANDALONE=false
